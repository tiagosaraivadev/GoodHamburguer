@page "/pedidos"
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@inject PedidoService PedidoService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Pedidos</h3>
        <button class="btn btn-success" @onclick="AbrirNovoPedido">+ Novo Pedido</button>
    </div>

    @if (_mostrarFormulario)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">@(_pedidoEditandoId.HasValue ? "Editar Pedido" : "Novo Pedido")</h5>

                @foreach (var item in _cardapio)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                               id="item_@item.Id"
                               @bind="_checkboxes[item.Id]" />
                        <label class="form-check-label" for="item_@item.Id">
                            @item.Nome — R$ @item.Preco.ToString("F2") (@item.Tipo)
                        </label>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_erro))
                {
                    <div class="alert alert-danger mt-3">@_erro</div>
                }

                <div class="mt-3">
                    <button class="btn btn-success me-2" @onclick="Salvar">Salvar</button>
                    <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                </div>
            </div>
        </div>
    }

    @if (_carregando)
    {
        <p>Carregando...</p>
    }
    else if (!_pedidos.Any())
    {
        <p>Nenhum pedido encontrado.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Data</th>
                    <th>Itens</th>
                    <th>Subtotal</th>
                    <th>Desconto</th>
                    <th>Total</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pedido in _pedidos)
                {
                    <tr>
                        <td>@pedido.Id</td>
                        <td>@pedido.DataCriacao.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@string.Join(", ", pedido.Itens.Select(i => i.Nome))</td>
                        <td>R$ @pedido.Subtotal.ToString("F2")</td>
                        <td>R$ @pedido.Desconto.ToString("F2")</td>
                        <td>R$ @pedido.Total.ToString("F2")</td>
                        <td>
                            <button class="btn btn-sm btn-primary me-1" @onclick="() => AbrirEdicao(pedido)">Editar</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => Remover(pedido.Id)">Remover</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<PedidoModel> _pedidos = new();
    private List<ItemModel> _cardapio = new();
    private Dictionary<int, bool> _checkboxes = new();
    private bool _carregando = true;
    private bool _mostrarFormulario = false;
    private int? _pedidoEditandoId = null;
    private string _erro = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _cardapio = await PedidoService.ObterCardapioAsync();
        await CarregarPedidos();
    }

    private async Task CarregarPedidos()
    {
        _carregando = true;
        _pedidos = await PedidoService.ListarPedidosAsync();
        _carregando = false;
    }

    private void InicializarCheckboxes()
    {
        _checkboxes = _cardapio.ToDictionary(i => i.Id, i => false);
    }

    private void AbrirNovoPedido()
    {
        _pedidoEditandoId = null;
        _erro = string.Empty;
        InicializarCheckboxes();
        _mostrarFormulario = true;
    }

    private void AbrirEdicao(PedidoModel pedido)
    {
        _pedidoEditandoId = pedido.Id;
        _erro = string.Empty;
        InicializarCheckboxes();
        foreach (var item in pedido.Itens)
            _checkboxes[item.Id] = true;
        _mostrarFormulario = true;
    }

    private async Task Salvar()
    {
        _erro = string.Empty;
        var request = new PedidoRequestModel
        {
            ItensId = _checkboxes.Where(x => x.Value).Select(x => x.Key).ToList()
        };

        try
        {
            if (_pedidoEditandoId.HasValue)
                await PedidoService.AtualizarPedidoAsync(_pedidoEditandoId.Value, request);
            else
                await PedidoService.CriarPedidoAsync(request);

            _mostrarFormulario = false;
            await CarregarPedidos();
        }
        catch (Exception ex)
        {
            _erro = ex.Message;
        }
    }

    private async Task Remover(int id)
    {
        await PedidoService.RemoverPedidoAsync(id);
        await CarregarPedidos();
    }

    private void Cancelar()
    {
        _mostrarFormulario = false;
        _erro = string.Empty;
    }
}